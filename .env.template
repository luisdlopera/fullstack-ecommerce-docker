# Docker compose shared environment
POSTGRES_USER=nexstore
POSTGRES_PASSWORD=nexstore
POSTGRES_DB=nexstore
POSTGRES_PORT=5432

# Public URL used by the browser (front -> back)
NEXT_PUBLIC_API_URL=http://localhost:4000/api
FRONTEND_ORIGIN=http://localhost:3000

# Optional local backend connection string when running without Docker
DATABASE_URL=postgresql://nexstore:nexstore@localhost:5432/nexstore?schema=public

# Auth
JWT_SECRET=replace-with-a-long-random-secret #openssl rand -hex 64
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Checkout
TAX_RATE=0.15

# Mercado Pago
MP_ACCESS_TOKEN=replace-with-mercadopago-access-token
