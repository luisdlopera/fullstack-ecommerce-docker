PORT=4000
# Use 127.0.0.1 for local `npm run dev:apps`; Docker Compose sets `postgres` for the back container.
DATABASE_URL=postgresql://nexstore:nexstore@127.0.0.1:5432/nexstore?schema=public
CORS_ORIGIN=http://localhost:3000
ENABLE_SWAGGER=false
JWT_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
TAX_RATE=0.15
MP_ACCESS_TOKEN=replace-with-mercadopago-access-token
