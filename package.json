{
  "name": "nexstore",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "front",
    "back"
  ],
  "scripts": {
    "dev": "npm run dev -w front",
    "dev:front": "npm run dev -w front",
    "dev:back": "npm run start:dev -w back",
    "build": "npm run build -w front && npm run build -w back",
    "start": "docker compose up --build",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "lint": "npm run lint -w front && npm run lint -w back"
  }
}
