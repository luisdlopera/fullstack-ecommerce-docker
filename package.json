{
  "name": "nexstore",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "front",
    "back"
  ],
  "scripts": {
    "dev": "npm run dev -w front",
    "dev:front": "npm run dev -w front",
    "dev:back": "npm run start:dev -w back",
    "build": "npm run build -w front && npm run build -w back",
    "start": "docker compose up --build",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "dev:up": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up",
    "dev:build": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up --build",
    "dev:down": "docker compose -f docker-compose.yml -f docker-compose.dev.yml down",
    "dev:clean": "docker compose -f docker-compose.yml -f docker-compose.dev.yml down -v && docker compose -f docker-compose.yml -f docker-compose.dev.yml up --build",
    "dc:dev": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up",
    "dc:dev:build": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up --build",
    "dc:down": "docker compose -f docker-compose.yml -f docker-compose.dev.yml down",
    "lint": "npm run lint -w front && npm run lint -w back"
  }
}
